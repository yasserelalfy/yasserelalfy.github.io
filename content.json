  "research": {
    "overview": {
      "text": "My research focuses on bridging the gap between raw sensor data and high-level spatial understanding. I develop monocular depth estimation models and integrate them into SLAM pipelines to enable 3D mapping without expensive LiDAR hardware.",
      "researchAreas": [
        "Monocular Depth Estimation",
        "Visual SLAM & Navigation",
        "Road Anomaly Characterization",
        "Edge AI for Robotics",
        "3D Mapping",
        "Scene Understanding"
      ]
    },
    "themes": [
      {
        "title": "3D SLAM",
        "description": "Spatial localization and mapping using monocular vision and deep learning."
      },
      {
        "title": "Road Anomaly Detection",
        "description": "Real-time identification and characterization of potholes and road hazards."
      },
      {
        "title": "Learning-Based Perception",
        "description": "Improving robustness of perception models in challenging environmental conditions."
      }
    ],
    "projects": [
      {
        "title": "Road Anomaly Detection System",
        "details": "A real-time edge system that identifies road hazards and estimates their depth using a single camera.",
        "linkText": "View Thesis",
        "linkUrl": "https://pure.kfupm.edu.sa/en/studentTheses/monocular-depth-estimation-using-deep-learning-for-3d-slam-mappin/",
        "category": "Anomaly Detection"
      },
      {
        "title": "3D SLAM Integration",
        "details": "Coupling monocular depth estimators with ORB-SLAM3 for dense volumetric mapping.",
        "linkText": "View Paper",
        "linkUrl": "https://cdnsciencepub.com/doi/10.1139/dsa-2024-0025",
        "category": "3D SLAM"
      }
    ],
